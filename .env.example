# 이 파일을 .env로 복사한 뒤 값을 채우세요. (.env는 git에 커밋하지 말 것)
# FortiProxy 3개 값(host/token/resource name)은 웹 대시보드 설정 패널에서도 입력 가능하며,
# 그 경우 DB에 저장된 값이 여기 .env 값보다 우선합니다. main.py(cron)만 쓸 거라면 여기를 채우세요.

FORTIPROXY_HOST=your-fortiproxy-host-or-ip
FORTIPROXY_TOKEN=여기에_REST_API_Bearer_토큰
FORTIPROXY_RESOURCE_NAME=3rd_feed

VERIFY_SSL=false
DB_PATH=urls.db
LOG_PATH=sync.log
MAX_PUSH_PER_RUN=500

# 웹 대시보드 바인딩 (기본은 로컬만 허용). 외부에서 접속해야 하면 0.0.0.0으로 바꾸되,
# 그 경우 반드시 Nginx 등 리버스 프록시 + HTTPS를 앞단에 두는 것을 권장.
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=5050
# 절대 운영 환경에서 true로 두지 말 것 (Werkzeug 디버거 원격 코드 실행 위험)
FLASK_DEBUG=false
